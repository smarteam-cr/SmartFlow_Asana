# =============================================
# Configuración de la Integración HubSpot ↔ Asana
# Copia este archivo a .env y completa los valores
# =============================================

# --- URL base de la app (producción) ---
APP_URL=https://tu-dominio.com

# --- Servidor ---
PORT=3005

# --- MongoDB ---
MONGO_URI=mongodb://app_user:tu-contraseña@mongo:27017/asana_hubspot?authSource=asana_hubspot
MONGO_DB=asana_hubspot

# --- HubSpot API ---
HUBSPOT_TOKEN=pat-XXXX-XXXX
# Un pipeline distinto por país → varios IDs de etapa separados por coma.
# El N-ésimo id de ANALISIS corresponde al N-ésimo id de PROPUESTA (mismo pipeline, mismo orden).
HUBSPOT_STAGE_ANALISIS=qualifiedtobuy,poner-id-etapa-analisis-pipeline-2
HUBSPOT_STAGE_PROPUESTA=presentationscheduled,poner-id-etapa-propuesta-pipeline-2
HUBSPOT_STAGE_GANADA=closedwon,poner-id-etapa-ganada-pipeline-2
HUBSPOT_OWNER_ID=poner-id-del-owner

# --- Asana API ---
ASANA_TOKEN=poner-token-de-asana
ASANA_WORKSPACE_GID=1201861044080787

# Proyecto Cuantificación
ASANA_PROJECT_GID=poner-project-gid
ASANA_BREINER_USER_GID=poner-user-gid

# Proyecto Planos de Despiece
ASANA_PLANOS_PROJECT_GID=poner-project-gid
ASANA_PLANOS_SECTION_GID=poner-section-gid
ASANA_PLANOS_ASSIGNEE_GID=poner-assignee-gid

# Proyecto VENTAS
ASANA_VENTAS_PROJECT_GID=poner-project-gid

# Mapa de usuarios Asana → Owners HubSpot (JSON)
ASANA_HUBSPOT_OWNER_MAP={"poner-asana-user-gid":"poner-hubspot-owner-id"}

# Tag de HubSpot en Asana
ASANA_HUBSPOT_TAG_NAME=HubSpot
